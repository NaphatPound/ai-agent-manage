# ─── Gateway (claude-code-runner/server.js) ──────────────────
# HTTP + WebSocket port exposed on the host
PORT=3456

# Where the gateway finds the RAG/chat service (ai-assistant)
ASSISTANT_URL=http://localhost:3000

# Ollama daemon — default is local; set to https://ollama.com for Ollama Cloud
OLLAMA_URL=http://localhost:11434
# If using Ollama Cloud, put your bearer token here
OLLAMA_AUTH_TOKEN=

# Point the `ollama` CLI at the local daemon when the runner spawns it
OLLAMA_HOST=http://localhost:11434

# Optional — bearer token to protect /api/*
# API_KEY=change-me

# Optional — enables Claude-powered stall detection on long runner tasks
# ANTHROPIC_API_KEY=sk-ant-...
# STALL_DETECTION=true

# ─── RAG service (ai-assistant/src/index.ts) ─────────────────
# Port the RAG service listens on (kept internal; gateway proxies /assistant/*)
AI_ASSISTANT_PORT=3000

# Postgres connection — update user/password if your local install differs
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_assistant

# Models used for embeddings + chat — must be pulled via `ollama pull`
EMBEDDING_MODEL=nomic-embed-text
CHAT_MODEL=llama3.2:1b
OLLAMA_API_URL=http://localhost:11434
